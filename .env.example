# Copy this file to `.env` and fill in the values.
# `.env` is git-ignored; `.env.example` is committed as a template.

# Anthropic API key — used by aegis's LLM-judge layers
# (`design_fidelity`, `feature_coverage`). Without this set, those
# layers skip cleanly.
#
# Obtain at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
